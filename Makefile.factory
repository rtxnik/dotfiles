# GENERATED by workflow-factory materialize - consumer fabric gate targets.
# Invoked by .github/workflows/fabric-gates.yml and `factory verify --trust` as
# `make -f Makefile.factory <target>`. Deliberately a SEPARATE file: it never
# collides with a consumer's product Makefile and is never included by it.
# The self-host-only bundle-manifest gate is deliberately absent.

.PHONY: hooks-test
hooks-test:
	shellcheck -x .claude/hooks/*.sh .claude/hooks/lib/*.sh .claude/hooks/tests/*.sh
	@for t in .claude/hooks/tests/test-*.sh; do echo "== $$t =="; bash "$$t" || exit 1; done

.PHONY: integration-check
integration-check:
	shellcheck scripts/integration-check.sh scripts/check-integration-*.sh scripts/gen-hooks-readme.sh
	bash scripts/integration-check.sh

.PHONY: ci-scripts-test
ci-scripts-test:
	shellcheck -x scripts/ci/*.sh scripts/ci/tests/test-*.sh
	@for t in scripts/ci/tests/test-*.sh; do echo "== $$t =="; bash "$$t" || exit 1; done

.PHONY: scripts-test
scripts-test:
	shellcheck -x scripts/*.sh scripts/lib/*.sh scripts/lib/tests/test-*.sh scripts/tests/test-*.sh
	@for t in scripts/lib/tests/test-*.sh scripts/tests/test-*.sh; do [ -e "$$t" ] || continue; echo "== $$t =="; bash "$$t" || exit 1; done
