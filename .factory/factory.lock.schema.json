{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rtxnik/workflow-factory/.factory/factory.lock.schema.json",
  "title": "factory.lock — workflow-factory generated lock (lock_format 1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["lock_format", "factory_version", "engine_floor", "source_sha", "release_digest",
               "provenance", "host_prereqs", "profile", "resolved_capabilities", "files"],
  "properties": {
    "lock_format": { "const": 1 },
    "factory_version": { "type": ["string", "null"] },
    "engine_floor": { "type": ["string", "null"] },
    "source_sha": { "type": ["string", "null"], "pattern": "^[0-9a-f]{40}$" },
    "release_digest": { "type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$" },
    "provenance": {
      "type": ["object", "null"],
      "properties": { "predicate_type": { "type": ["string", "null"] } }
    },
    "host_prereqs": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tool", "detect_cmd", "install_guidance"],
        "properties": {
          "tool": { "type": "string" },
          "detect_cmd": { "type": "string" },
          "install_guidance": { "type": "string" }
        }
      }
    },
    "profile": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "resolved_capabilities": { "type": "array", "items": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" } },
    "files": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sha256", "capabilities", "provenance"],
        "properties": {
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "capabilities": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" } },
          "provenance": { "enum": ["base", "rendered", "assembled", "regenerated", "seed-once", "overlay"] }
        }
      }
    }
  }
}
